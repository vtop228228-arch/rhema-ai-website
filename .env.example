# Скопируй этот файл в .env.local и заполни свои значения
# cp .env.example .env.local

# ── Telegram — уведомления о заявках ──
# Создай бота через @BotFather → получи токен
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Твой личный Telegram ID (узнать через @userinfobot)
TELEGRAM_CHAT_ID=123456789

# ── Anthropic — AI-агент диагностики ──
# Получить на: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase — опционально (без него лиды идут только в Telegram) ──
# Создать проект на: https://supabase.com
# Применить миграцию: supabase/diagnostic.sql
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── JARVIS CRM — лиды дублируются в jarvis.leads через edge-функцию lead-intake ──
# Без этих двух переменных лиды идут только в Telegram (мягкий skip, форма не падает).
# URL фиксирован; секрет — общий с edge-функцией (на сервере сверяется его SHA-256).
LEAD_INTAKE_URL=https://oilfdnzqdjqyfpxqszpx.supabase.co/functions/v1/lead-intake
LEAD_INTAKE_SECRET=<секрет — запросить у Влада / см. Vercel env>
